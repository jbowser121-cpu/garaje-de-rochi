# Copia este archivo como .env y completa los valores.

# --- Tienda ---
PORT=3000

# --- Panel de moderador (http://localhost:3000/admin.html) ---
# CAMBIA estas credenciales por unas tuyas antes de usar en producción.
ADMIN_USER=admin
ADMIN_PASS=rochi123

# --- Bots (URL de la API de la tienda que consultan) ---
API_URL=http://localhost:3000

# --- Instagram (Meta Graph API) ---
# Token que TÚ inventas y registras en el webhook de Meta:
IG_VERIFY_TOKEN=nutrivida_verify
# Token de acceso de la Página de Facebook vinculada a la cuenta de Instagram:
IG_PAGE_ACCESS_TOKEN=
IG_PORT=3100

# WhatsApp (whatsapp-web.js) no necesita claves: se conecta por QR.

# --- Pago con Wompi (PSE / tarjeta débito o crédito) ---
# Regístrate en https://comercios.wompi.co y vincula tu cuenta bancaria (ahí llega el dinero).
# Copia tus llaves (Ajustes > Llaves API). El secreto de integridad nunca se comparte.
WOMPI_PUBLIC_KEY=
WOMPI_INTEGRITY_SECRET=
